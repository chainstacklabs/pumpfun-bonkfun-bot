# =============================================================================
# PUMP.FUN SNIPER BOT - PRODUCTION CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# All configuration is via environment variables - no YAML configs needed

# =============================================================================
# WALLET & RPC
# =============================================================================
# Your Solana wallet private key (base58 encoded)
PRIVATE_KEY=your_base58_private_key_here

# Solana RPC endpoint (use a fast RPC provider like Helius, QuickNode, Triton)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_api_key

# =============================================================================
# GEYSER (Yellowstone gRPC) - REQUIRED
# =============================================================================
# Geyser gRPC endpoint (e.g., from Helius, Triton, or your own validator)
GEYSER_ENDPOINT=grpc.your-geyser-provider.io:443

# Geyser API token for authentication
GEYSER_API_TOKEN=your_geyser_api_token

# Authentication type: "x-token" or "basic"
GEYSER_AUTH_TYPE=x-token

# =============================================================================
# JITO BUNDLES - MEV PROTECTION & SANDWICH RESISTANCE
# =============================================================================
# Jito Block Engine URL (mainnet)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Jito tip amount in lamports (e.g., 10000 = 0.00001 SOL)
# Higher tips = faster inclusion, better sandwich protection
JITO_TIP_LAMPORTS=50000

# Jito tip account (one of the 8 official tip accounts, rotated automatically)
# Leave empty to use random tip account selection
JITO_TIP_ACCOUNT=

# =============================================================================
# TRADING PARAMETERS
# =============================================================================
# Amount of SOL to spend on each buy (in SOL, not lamports)
BUY_AMOUNT_SOL=0.05

# Slippage tolerance for buys (0.3 = 30%)
BUY_SLIPPAGE=0.3

# Slippage tolerance for sells (0.2 = 20%)
SELL_SLIPPAGE=0.2

# Compute unit limit for buy transactions
COMPUTE_UNITS_BUY=120000

# Compute unit limit for sell transactions
COMPUTE_UNITS_SELL=80000

# Priority fee in microlamports (used as fallback if Jito fails)
PRIORITY_FEE_MICROLAMPORTS=500000

# =============================================================================
# EXIT STRATEGY
# =============================================================================
# Exit strategy: "time_based" or "tp_sl" or "immediate"
# - time_based: Hold for MAX_HOLD_TIME_SECONDS then sell
# - tp_sl: Sell on take profit or stop loss
# - immediate: Buy and immediately sell (for testing)
EXIT_STRATEGY=time_based

# Maximum time to hold a position (seconds) - for time_based strategy
MAX_HOLD_TIME_SECONDS=60

# Take profit percentage (0.5 = 50% profit) - for tp_sl strategy
TAKE_PROFIT_PERCENT=0.5

# Stop loss percentage (0.2 = 20% loss) - for tp_sl strategy
STOP_LOSS_PERCENT=0.2

# Price check interval in seconds - for tp_sl strategy
PRICE_CHECK_INTERVAL=2

# =============================================================================
# FILTERS
# =============================================================================
# Only buy tokens with names/symbols containing this string (case-insensitive)
# Leave empty to buy any new token
MATCH_STRING=

# Only buy tokens from this creator address
# Leave empty to buy from any creator
CREATOR_ADDRESS=

# Maximum token age in seconds (skip tokens older than this)
MAX_TOKEN_AGE_SECONDS=5

# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================
# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to send notifications to
TELEGRAM_CHAT_ID=

# Enable/disable Telegram notifications (true/false)
TELEGRAM_ENABLED=false

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================
# Account data size limit in bytes (reduces CU cost)
ACCOUNT_DATA_SIZE_LIMIT=512000

# Skip preflight checks for faster submission
SKIP_PREFLIGHT=true

# Maximum retries for transaction submission
MAX_TX_RETRIES=3

# RPC request timeout in seconds
RPC_TIMEOUT=10

# Enable debug logging (true/false)
DEBUG=false
